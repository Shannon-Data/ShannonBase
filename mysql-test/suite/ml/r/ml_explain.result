create table census_train_10 as select * from shannon_ml_explain.census_train order by age,workclass,fnlwgt,education limit 10;
ALTER TABLE census_train_10 ADD PRIMARY KEY (id);
alter table shannon_ml_explain.census_train_10 secondary_engine=rapid;
alter table shannon_ml_explain.census_train_10 secondary_load;
CALL sys.ML_EXPLAIN_TABLE('shannon_ml_explain.census_train_10', @census_model, 'shannon_ml_explain.census_train_permutation', 
JSON_OBJECT('prediction_explainer', 'permutation_importance', 'batch_size', '10'));
