##############################################################################
# ShannonBase test case for ML functions.
# ShannonBase copyright 2023-
##############################################################################

--disable_warnings
--let $ml_schema = `SELECT CONCAT('ML_SCHEMA_', SUBSTRING_INDEX(CURRENT_USER(), '@', 1))`

--eval DROP DATABASE IF EXISTS $ml_schema

SET GLOBAL local_infile = 1;
DROP DATABASE IF EXISTS shannon_ml_explain;
CREATE DATABASE shannon_ml_explain;
ALTER DATABASE shannon_ml_explain CHARACTER SET ascii COLLATE ascii_bin;
USE shannon_ml_explain;
--enable_warnings

CREATE TABLE census_train (
    age INT,
    workclass VARCHAR(255),
    fnlwgt INT,
    education VARCHAR(255),
    `education-num` INT,
    `marital-status` VARCHAR(255),
    occupation VARCHAR(255),
    relationship VARCHAR(255),
    race VARCHAR(255),
    sex VARCHAR(255),
    `capital-gain` INT,
    `capital-loss` INT,
    `hours-per-week` INT,
    `native-country` VARCHAR(255),
    revenue VARCHAR(255)
);

CREATE TABLE census_test LIKE census_train;

--disable_query_log
--eval LOAD DATA INFILE '$MYSQLTEST_VARDIR/std_data/ml/census/census_train_load.csv' INTO TABLE census_train FIELDS TERMINATED BY ','
--eval LOAD DATA INFILE '$MYSQLTEST_VARDIR/std_data/ml/census/census_test_load.csv' INTO TABLE census_test FIELDS TERMINATED BY ','
ALTER TABLE census_train ADD COLUMN id INT AUTO_INCREMENT NOT SECONDARY PRIMARY KEY FIRST;
ALTER TABLE census_test ADD COLUMN id INT AUTO_INCREMENT NOT SECONDARY PRIMARY KEY FIRST;

ALTER TABLE census_train SECONDARY_ENGINE = RAPID;
ALTER TABLE census_test SECONDARY_ENGINE = RAPID;
--enable_query_log

SET @census_model = 'census_test_train';
ALTER TABLE census_train SECONDARY_LOAD;

SET @census_model = 'census_test_train1';
CALL sys.ML_TRAIN('shannon_ml_explain.census_train', 'revenue', JSON_OBJECT('task', 'classification'), @census_model);

# 检查训练后 MODEL_EXPLANATION 是否为 NULL
--eval SELECT MODEL_EXPLANATION IS NULL AS explanation_is_null FROM $ml_schema.MODEL_CATALOG

CALL sys.ML_MODEL_LOAD(@census_model, NULL);
CALL sys.ML_EXPLAIN('shannon_ml_explain.census_train', 'revenue', @census_model, NULL);

# 检查 EXPLAIN 后 MODEL_EXPLANATION 是否不为 NULL
--eval SELECT MODEL_EXPLANATION IS NOT NULL AS explanation_is_not_null FROM $ml_schema.MODEL_CATALOG

SET @row_input = JSON_OBJECT( 
          "age", 31, 
          "workclass", "Private", 
          "fnlwgt", 45781, 
          "education", "Masters", 
          "education-num", 14, 
          "marital-status", "Married-civ-spouse", 
          "occupation", "Prof-specialty", 
          "relationship", "Not-in-family", 
          "race", "White", 
          "sex", "Female", 
          "capital-gain", 14084, 
          "capital-loss", 2042, 
          "hours-per-week", 40, 
          "native-country", "India");
--replace_column 1 IGNORE
SELECT sys.ML_EXPLAIN_ROW(@row_input, @census_model, JSON_OBJECT('prediction_explainer', 'permutation_importance'));


--replace_column 1 IGNORE
SELECT sys.ML_EXPLAIN_ROW(JSON_OBJECT(
    "age", census_train.`age`,
    "workclass", census_train.`workclass`,
    "fnlwgt", census_train.`fnlwgt`,
    "education", census_train.`education`,
    "education-num", census_train.`education-num`,
    "marital-status", census_train.`marital-status`,
    "occupation", census_train.`occupation`,
    "relationship", census_train.`relationship`,
    "race", census_train.`race`,
    "sex", census_train.`sex`,
    "capital-gain", census_train.`capital-gain`,
    "capital-loss", census_train.`capital-loss`,
    "hours-per-week", census_train.`hours-per-week`,
    "native-country", census_train.`native-country`),
    @census_model, JSON_OBJECT('prediction_explainer', 'shap'))FROM census_train LIMIT 2;

# 清理：删除当前用户的 ML schema
--eval DROP DATABASE IF EXISTS $ml_schema

ALTER TABLE census_train SECONDARY_UNLOAD;
DROP DATABASE IF EXISTS shannon_ml_explain;