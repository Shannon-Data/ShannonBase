# Tests for the SECONDARY_ENGINE table option.
# Most DDLs are allowed on tables with SECONDARY_ENGINE when
# the corresponding SECONDARY_ENGINE plugin is not installed.
# Following tests are with SECONDARY_ENGINE plugin that doesn't exist.

# USED FOR RAG.
create database sh_javascript_sp;
use sh_javascript_sp;
--disable_warnings

CREATE TABLE js_sp_test (
    id INT AUTO_INCREMENT PRIMARY KEY,
    segment VARCHAR(255) NOT NULL,
    text VARCHAR(255) NOT NULL,
    document_name VARCHAR(100) DEFAULT NULL,
    segment_number INT DEFAULT 1,
    metadata JSON DEFAULT (JSON_OBJECT())
) ENGINE=InnoDB;        

INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata)
VALUES 
('What is AutoML?', ('AutoML explanation example text'), 'doc1', 1, JSON_OBJECT('category', 'AI')),
('AutoML automates model building', ('AutoML automates model building'), 'doc1', 2, JSON_OBJECT('category', 'AI')),
('Machine learning basics', ('Basics of machine learning'), 'doc2', 1, JSON_OBJECT('category', 'ML')),
('ShannonBase is an AI-native SQL engine', ('ShannonBase overview'), 'doc3', 1, JSON_OBJECT('category', 'DB'));

DELIMITER |;
CREATE PROCEDURE SELECT_DATA_PROC ()
LANGUAGE JAVASCRIPT AS $$
   var rs = sys.exec_sql("SELECT id + 0 AS id, segment, text, document_name, segment_number, metadata FROM js_sp_test");
   sys.send_result_set(rs);
$$|

CREATE PROCEDURE SELECT_EMPTY_DATA_PROC ()
LANGUAGE JAVASCRIPT AS $$
   var rs = sys.exec_sql("SELECT id + 0 AS id, segment, text, document_name, segment_number, metadata FROM js_sp_test where id = 100");
   sys.send_result_set(rs);
$$|

CREATE FUNCTION SELECT_JSON_META () RETURNS TEXT
LANGUAGE JAVASCRIPT AS $$
function select_json_meta() {
   var rs = sys.exec_sql("SELECT id, segment FROM js_sp_test WHERE id = 1");
   var result = JSON.stringify({columns: rs.columns, cursor_id: rs.__cursor_id, has_cursor: typeof rs.__cursor_id === 'number'});
   sys.close_result_set(rs);
   return result;
}
return select_json_meta();
$$|

CREATE FUNCTION CURSOR_FUNC_TESTS () RETURNS TEXT
LANGUAGE JAVASCRIPT AS $$
function cursor_func_tests() {
   var r = {};

   // Test 1: SELECT returns cursor with columns
   var rs1 = sys.exec_sql("SELECT id, segment FROM js_sp_test WHERE id = 1");
   r.t1_has_cursor = typeof rs1.__cursor_id === 'number';
   r.t1_has_columns = Array.isArray(rs1.columns);
   r.t1_col_count  = rs1.columns.length;
   sys.close_result_set(rs1);

   // Test 2: empty result still returns cursor
   var rs2 = sys.exec_sql("SELECT id FROM js_sp_test WHERE id = 999");
   r.t2_has_cursor = typeof rs2.__cursor_id === 'number';
   r.t2_has_columns = Array.isArray(rs2.columns);
   sys.close_result_set(rs2);

   // Test 3: close_result_set is idempotent
   var rs3 = sys.exec_sql("SELECT 1 AS n");
   r.t3_close_1st = sys.close_result_set(rs3);
   r.t3_close_2nd = sys.close_result_set(rs3);

   // Test 4: DML returns affected_rows, no cursor
   var rs4 = sys.exec_sql("INSERT INTO js_sp_test (segment, text) VALUES('c', 'fn')");
   r.t4_no_cursor   = typeof rs4.__cursor_id === 'undefined';
   r.t4_affected    = typeof rs4.affected_rows === 'number';

   return JSON.stringify(r);
}
return cursor_func_tests();
$$|

CREATE FUNCTION INSERT_DATA () RETURNS TEXT
LANGUAGE JAVASCRIPT AS $$
function insert_data() {
   let sql = "INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata) VALUES('Test Segment', 'Test Text', 'test_doc', 1, JSON_OBJECT('key', 'value'))";
   sys.exec_sql(sql);
   let sql2 = "INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata) VALUES('AutoML building', 'AutoML automates model building', 'doc1', 2, JSON_OBJECT('category', 'AI'))";
   return JSON.stringify(sys.exec_sql(sql2));
}
return insert_data();
$$|

CREATE FUNCTION UPDATE_DATA_SIMPLE () RETURNS TEXT
LANGUAGE JAVASCRIPT AS $$
function update_data_simple() {
   return JSON.stringify(sys.exec_sql("UPDATE js_sp_test SET segment = 'Simple Update' WHERE id = 1"));
}
return update_data_simple();
$$|

DELIMITER ;|

CALL SELECT_DATA_PROC();
CALL SELECT_EMPTY_DATA_PROC();

SELECT SELECT_JSON_META();

SELECT CURSOR_FUNC_TESTS();

SELECT INSERT_DATA();
SELECT * FROM js_sp_test ORDER BY ID;

select UPDATE_DATA_SIMPLE();
SELECT * FROM js_sp_test ORDER BY ID;

--echo #
--echo # JavaScript PROCEDURE tests
--echo #

--echo # 1. Basic JS PROCEDURE (no parameters, DML via INSERT)
DELIMITER |;
CREATE PROCEDURE js_proc_no_param ()
LANGUAGE JAVASCRIPT
AS $$
  sys.exec_sql("INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata) VALUES('JS Proc Basic', 'Hello from JS PROCEDURE', 'js_proc_basic', 1, JSON_OBJECT('src', 'js_proc'))");
$$|
DELIMITER ;|

CALL js_proc_no_param();
SELECT id, segment, document_name FROM js_sp_test WHERE document_name = 'js_proc_basic' ORDER BY id;

--echo # Verify metadata
SHOW CREATE PROCEDURE js_proc_no_param;
--replace_column 6 <modified> 7 <created>
SHOW PROCEDURE STATUS WHERE Name = 'js_proc_no_param';
SELECT routine_name, routine_type, routine_body,
       external_name, external_language, parameter_style
FROM information_schema.routines
WHERE routine_name = 'js_proc_no_param';

DROP PROCEDURE js_proc_no_param;

--echo # 2. JS PROCEDURE with IN parameter
DELIMITER |;
CREATE PROCEDURE js_proc_in_param (IN x INTEGER)
LANGUAGE JAVASCRIPT
AS $$
  sys.exec_sql("INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata) VALUES(CONCAT('JS Proc Param ', " + x + "), CONCAT('Value: ', " + x + "), 'js_proc_param', " + x + ", JSON_OBJECT('val', " + x + "))");
$$|
DELIMITER ;|

CALL js_proc_in_param(21);
CALL js_proc_in_param(42);
SELECT id, segment, document_name, segment_number FROM js_sp_test WHERE document_name = 'js_proc_param' ORDER BY id;

--echo # Verify metadata
SHOW CREATE PROCEDURE js_proc_in_param;
--replace_column 6 <modified> 7 <created>
SHOW PROCEDURE STATUS WHERE Name = 'js_proc_in_param';
SELECT routine_name, routine_type, routine_body,
       external_name, external_language, parameter_style
FROM information_schema.routines
WHERE routine_name = 'js_proc_in_param';

DROP PROCEDURE js_proc_in_param;

--echo # 3. JS PROCEDURE executing SELECT on a real table
DELIMITER |;
CREATE PROCEDURE js_proc_table_query ()
LANGUAGE JAVASCRIPT
AS $$
  sys.exec_sql("INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata) VALUES('JS Proc Table', 'Table test', 'js_proc_table', 1, JSON_OBJECT('test', 'table_query'))");
$$|
DELIMITER ;|

CALL js_proc_table_query();
SELECT id, segment, document_name FROM js_sp_test WHERE document_name = 'js_proc_table' ORDER BY id;

DROP PROCEDURE js_proc_table_query;

--echo # 4. JS PROCEDURE with INSERT (procedures allow DML)
DELIMITER |;
CREATE PROCEDURE js_proc_insert (IN seg TEXT, IN txt TEXT)
LANGUAGE JAVASCRIPT
AS $$
  sys.exec_sql("INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata) VALUES('" + seg + "', '" + txt + "', 'js_proc_doc', 1, JSON_OBJECT('src', 'js_proc'))");
$$|
DELIMITER ;|

CALL js_proc_insert('JS Proc Insert', 'Inserted by JS procedure');
SELECT id, segment, document_name FROM js_sp_test WHERE document_name = 'js_proc_doc' ORDER BY id;

DROP PROCEDURE js_proc_insert;

--echo # 5. DROP TABLE cleanup for JS proc tests
DELETE FROM js_sp_test WHERE document_name LIKE 'js_proc_%';

--echo # 6. Multiple JS PROCEDUREs — SHOW PROCEDURE STATUS filter
DELIMITER |;
CREATE PROCEDURE js_proc_a () LANGUAGE JAVASCRIPT AS $$ $$|
CREATE PROCEDURE js_proc_b () LANGUAGE JAVASCRIPT AS $$ $$|
DELIMITER ;|
--replace_column 6 <modified> 7 <created>
SHOW PROCEDURE STATUS WHERE Language = 'JAVASCRIPT';

DROP PROCEDURE js_proc_a;
DROP PROCEDURE js_proc_b;

--echo # 7. Error: using LANGUAGE JAVASCRIPT as procedure name
DELIMITER |;
--error ER_PARSE_ERROR
CREATE PROCEDURE JAVASCRIPT (a INTEGER)
LANGUAGE JAVASCRIPT
AS $$ let b = a; $$|
DELIMITER ;|

--echo # 8. Lower-case and mixed-case LANGUAGE (minimal body)
DELIMITER |;
CREATE PROCEDURE js_proc_lower (IN x INTEGER)
LANGUAGE javascript
AS $$
  var dummy = x;
$$|
DELIMITER ;|
CALL js_proc_lower(5);
DROP PROCEDURE js_proc_lower;

DELIMITER |;
CREATE PROCEDURE js_proc_mixed (IN x INTEGER)
LANGUAGE jAvaScRIpt
AS $$
  var dummy = x;
$$|
DELIMITER ;|
CALL js_proc_mixed(5);
DROP PROCEDURE js_proc_mixed;

--echo # 9. JS PROCEDURE with IN/OUT parameters (compute value in JS)
DELIMITER |;
CREATE PROCEDURE js_proc_inout (IN x INTEGER, OUT out_result TEXT)
LANGUAGE JAVASCRIPT
AS $$
  var val = x * 2;
  out_result = String(val);
  sys.exec_sql("SET @_js_out = '" + val + "'");
$$|
DELIMITER ;|

SET @_js_out = '';
SET @out_result = '';
CALL js_proc_inout(21, @out_result);
SELECT @out_result, @_js_out;
DROP PROCEDURE js_proc_inout;

--echo #
--echo # 10. sys.send_result_set — send structured result sets from JS procedures
--echo #

--echo # 10a. Basic send_result_set with JS object (single row, multiple columns)
DELIMITER |;
CREATE PROCEDURE js_proc_send_result_basic()
LANGUAGE JAVASCRIPT
AS $$
  sys.send_result_set({
    columns: ["response", "confidence"],
    rows: [
      ["Hello from JS send_result_set", 0.95]
    ]
  });
$$|
DELIMITER ;|

CALL js_proc_send_result_basic();
DROP PROCEDURE js_proc_send_result_basic;

--echo # 10b. send_result_set with multiple rows
DELIMITER |;
CREATE PROCEDURE js_proc_send_result_multi()
LANGUAGE JAVASCRIPT
AS $$
  sys.send_result_set({
    columns: ["table_name", "row_count", "engine"],
    rows: [
      ["users", 10000, "InnoDB"],
      ["orders", 50000, "InnoDB"],
      ["logs", 120000, "Rapid"]
    ]
  });
$$|
DELIMITER ;|

CALL js_proc_send_result_multi();
DROP PROCEDURE js_proc_send_result_multi;

--echo # 10c. send_result_set with empty rows (column headers only)
DELIMITER |;
CREATE PROCEDURE js_proc_send_result_empty()
LANGUAGE JAVASCRIPT
AS $$
  sys.send_result_set({
    columns: ["message"],
    rows: []
  });
$$|
DELIMITER ;|

CALL js_proc_send_result_empty();
DROP PROCEDURE js_proc_send_result_empty;

--echo # 10d. send_result_set with mixed types (null, boolean, float, string)
DELIMITER |;
CREATE PROCEDURE js_proc_send_result_mixed()
LANGUAGE JAVASCRIPT
AS $$
  sys.send_result_set({
    columns: ["name", "active", "score", "notes"],
    rows: [
      ["Alpha", true, 99.5, "top performer"],
      ["Beta", false, 72.3, null],
      [null, true, null, "no name given"]
    ]
  });
$$|
DELIMITER ;|

CALL js_proc_send_result_mixed();
DROP PROCEDURE js_proc_send_result_mixed;

--echo # 10e. send_result_set via JSON string
DELIMITER |;
CREATE PROCEDURE js_proc_send_result_json_str()
LANGUAGE JAVASCRIPT
AS $$
  sys.send_result_set(
    '{"columns":["col_a","col_b"],"rows":[["val1",42],["val2",99]]}'
  );
$$|
DELIMITER ;|

CALL js_proc_send_result_json_str();
DROP PROCEDURE js_proc_send_result_json_str;

--echo # 10f. send_result_set with IN parameter (dynamic data)
DELIMITER |;
CREATE PROCEDURE js_proc_send_result_param(IN prefix TEXT)
LANGUAGE JAVASCRIPT
AS $$
  sys.send_result_set({
    columns: ["key", "value"],
    rows: [
      [prefix + "_a", 1],
      [prefix + "_b", 2],
      [prefix + "_c", 3]
    ]
  });
$$|
DELIMITER ;|

CALL js_proc_send_result_param('test');
DROP PROCEDURE js_proc_send_result_param;

--echo # 10g. send_result_set row has fewer cells than columns (padded with NULL)
DELIMITER |;
CREATE PROCEDURE js_proc_send_result_short_row()
LANGUAGE JAVASCRIPT
AS $$
  sys.send_result_set({
    columns: ["a", "b", "c"],
    rows: [
      ["full", "row", "here"],
      ["short"]   /* only one cell — b and c should be NULL */
    ]
  });
$$|
DELIMITER ;|

CALL js_proc_send_result_short_row();
DROP PROCEDURE js_proc_send_result_short_row;

--echo # 10h. send_result_set with various number types (integer, negative, float)
DELIMITER |;
CREATE PROCEDURE js_proc_send_result_various_num()
LANGUAGE JAVASCRIPT
AS $$
  sys.send_result_set({
    columns: ["id", "value"],
    rows: [
      [1, 42],
      [2, -100],
      [3, 3.14]
    ]
  });
$$|
DELIMITER ;|

CALL js_proc_send_result_various_num();
DROP PROCEDURE js_proc_send_result_various_num;

--echo #
--echo # 11. Result set metadata — verify columns from sys.exec_sql (cursor mode)
--echo #

DELIMITER |;
CREATE FUNCTION RESULT_SET_SIZE () RETURNS TEXT
LANGUAGE JAVASCRIPT AS $$
function result_set_size() {
   var res = sys.exec_sql("SELECT id, segment, text FROM js_sp_test ORDER BY id");
   var info = {
     col_count: res.columns.length,
     columns: res.columns,
     has_cursor: typeof res.__cursor_id === 'number'
   };
   return JSON.stringify(info);
}
return result_set_size();
$$|
DELIMITER ;|

SELECT RESULT_SET_SIZE();
DROP FUNCTION RESULT_SET_SIZE;

--echo #
--echo # 12. sys.send_result_set with exec_sql cursor — stream rows to client
--echo #

DELIMITER |;
CREATE PROCEDURE STREAM_RESULT_SET ()
LANGUAGE JAVASCRIPT
AS $$
  var rs = sys.exec_sql("SELECT segment FROM js_sp_test ORDER BY id");
  sys.send_result_set(rs);
$$|
DELIMITER ;|

CALL STREAM_RESULT_SET();
DROP PROCEDURE STREAM_RESULT_SET;

--echo #
--echo # 13. sys.close_result_set — explicit cursor cleanup (no result sent)
--echo #

DELIMITER |;
CREATE FUNCTION CLOSE_RESULT_SET () RETURNS TEXT
LANGUAGE JAVASCRIPT AS $$
function close_result_set_test() {
   var rs = sys.exec_sql("SELECT * FROM js_sp_test WHERE id = 1");
   sys.close_result_set(rs);
   return "cursor_closed";
}
return close_result_set_test();
$$|
DELIMITER ;|

SELECT CLOSE_RESULT_SET();
DROP FUNCTION CLOSE_RESULT_SET;

--echo #
--echo # 14. PROCEDURE cursor tests — SELECT cursor, empty cursor, idempotent close, DML no cursor
--echo #

DELIMITER |;
CREATE PROCEDURE CURSOR_PROC_TESTS ()
LANGUAGE JAVASCRIPT
AS $$
  var t = {};

  // Test 1: SELECT returns cursor with columns
  var rs1 = sys.exec_sql("SELECT id, segment FROM js_sp_test WHERE id = 1");
  t.t1_cursor  = typeof rs1.__cursor_id === 'number';
  t.t1_columns = Array.isArray(rs1.columns);
  t.t1_col_cnt = rs1.columns.length;
  sys.close_result_set(rs1);

  // Test 2: empty result still returns cursor
  var rs2 = sys.exec_sql("SELECT id FROM js_sp_test WHERE id = 999");
  t.t2_cursor  = typeof rs2.__cursor_id === 'number';
  t.t2_columns = Array.isArray(rs2.columns);
  sys.close_result_set(rs2);

  // Test 3: close_result_set is idempotent
  var rs3 = sys.exec_sql("SELECT 1 AS n");
  t.t3_1st = sys.close_result_set(rs3);
  t.t3_2nd = sys.close_result_set(rs3);

  // Test 4: DML returns affected_rows, no cursor
  var rs4 = sys.exec_sql("INSERT INTO js_sp_test (segment, text) VALUES('proc_c', 'fn')");
  t.t4_no_cursor = typeof rs4.__cursor_id === 'undefined';
  t.t4_affected  = typeof rs4.affected_rows === 'number';
  sys.close_result_set(rs4);

  sys.send_result_set({
    columns: ["test", "result"],
    rows: [
      ["t1_cursor", String(t.t1_cursor)],
      ["t1_columns", String(t.t1_columns)],
      ["t1_col_cnt", String(t.t1_col_cnt)],
      ["t2_cursor", String(t.t2_cursor)],
      ["t2_columns", String(t.t2_columns)],
      ["t3_1st", String(t.t3_1st)],
      ["t3_2nd", String(t.t3_2nd)],
      ["t4_no_cursor", String(t.t4_no_cursor)],
      ["t4_affected", String(t.t4_affected)]
    ]
  });
$$|
DELIMITER ;|

CALL CURSOR_PROC_TESTS();
DROP PROCEDURE CURSOR_PROC_TESTS;

--enable_warnings
DROP DATABASE sh_javascript_sp;
