CALL sys.ML_RETRIEVE_SCHEMA_METADATA("How many score are there in total?", @output, NULL);
select  @output like "CREATE TABLE `sh_retrieve`.`tt1`(
  `score` int,
  `name` char(10),
  `id` int,
  `gender` char(1)
);

CREATE TABLE `sh_retrieve`.`tt4`(
  `score` double,
  `name` char(10),
  `id` int,
  `gender` char(1)
);%" as result;
result
1
