  id int [PK] [AUTO_INCREMENT]
  segment varchar(255) [NOT NULL]
  text varchar(255) [NOT NULL]
  document_name varchar(100)
  segment_number int
  metadata json
	0x49474E4F5245	1	IGNORE
IGNORE	sh_retrieve	orders	Table: sh_retrieve.orders
