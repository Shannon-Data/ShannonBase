delete from mysql.schema_embeddings;
create database sh_retrieve;
use sh_retrieve;
set global rapid_schema_embedding = true;
show variables like "rapid_schema_embedding";
Variable_name	Value
rapid_schema_embedding	ON
set global rapid_schema_embedding = false;
show variables like "rapid_schema_embedding";
Variable_name	Value
rapid_schema_embedding	OFF
set global rapid_schema_embedding = `1`;
ERROR 42000: Variable 'rapid_schema_embedding' can't be set to the value of '1'
show variables like "rapid_schema_embedding";
Variable_name	Value
rapid_schema_embedding	OFF
set global rapid_schema_embedding = `0`;
ERROR 42000: Variable 'rapid_schema_embedding' can't be set to the value of '0'
show variables like "rapid_schema_embedding";
Variable_name	Value
rapid_schema_embedding	OFF
set global rapid_schema_embedding = 11;
ERROR 42000: Variable 'rapid_schema_embedding' can't be set to the value of '11'
show variables like "rapid_schema_embedding";
Variable_name	Value
rapid_schema_embedding	OFF
set global rapid_schema_embedding = 1;
show variables like "rapid_schema_embedding";
Variable_name	Value
rapid_schema_embedding	ON
set global rapid_schema_embedding = 0;
show variables like "rapid_schema_embedding";
Variable_name	Value
rapid_schema_embedding	OFF
set global rapid_schema_embedding = 1;
CREATE TABLE demo_embeddings (
id INT AUTO_INCREMENT PRIMARY KEY,
segment VARCHAR(255) NOT NULL,
text VARCHAR(255) NOT NULL,
document_name VARCHAR(100) DEFAULT NULL,
segment_number INT DEFAULT 1,
metadata JSON DEFAULT (JSON_OBJECT())
) ENGINE=InnoDB;
CREATE TABLE users (
id INT PRIMARY KEY AUTO_INCREMENT,
username VARCHAR(50) NOT NULL,
email VARCHAR(100) UNIQUE NOT NULL,
age INT,
city VARCHAR(50),
created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) secondary_engine=rapid;
create table tt1 (score int, name char(10), id int, gender char(1), primary key(id, score)) secondary_engine=rapid;
CREATE TABLE orders (
id INT PRIMARY KEY AUTO_INCREMENT,
user_id INT,
product_name VARCHAR(100),
amount DECIMAL(10, 2),
order_date DATE,
FOREIGN KEY (user_id) REFERENCES users(id)
);
create table tt5 (name char(10) primary key) secondary_engine=rapid;
create table tt4 (score double primary key, name char(10), id int, gender char(1));
select * from mysql.schema_embeddings order by schema_name, table_name;
id	schema_name	table_name	doc_text	embedding	status	updated_at
IGNORE	sh_retrieve	demo_embeddings	Table: sh_retrieve.demo_embeddings
