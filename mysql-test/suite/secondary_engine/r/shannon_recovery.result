create database sh_test_recovery CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci;
use sh_test_recovery;
show variables like "rapid_reload_on_restart";
Variable_name	Value
rapid_reload_on_restart	OFF
set persist rapid_reload_on_restart =on;
show variables like "rapid_reload_on_restart";
Variable_name	Value
rapid_reload_on_restart	ON
CREATE TABLE `t1` (
`a` int NOT NULL,
PRIMARY KEY (`a`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci SECONDARY_ENGINE=RAPID;
create table tt1 (score int, name char(10), id int, gender char(1), primary key(id, score)) secondary_engine=rapid;
insert into tt1 values(10, 'n1', 1, 'm'), (20, 'n2', 2, 'f'), (30, 'n3', 3, 'm');
insert into tt1 values(1, 'n1', 1, 'm'), (2, 'n2', 2, 'f'), (3, 'n3', 3, 'm'), (40,'n4',4,'f');
alter table tt1 secondary_load;
SET SESSION optimizer_switch='hypergraph_optimizer=on';
select * from tt1 where score >=1  and id < 3 order by id;
score	name	id	gender
1	n1	1	m
10	n1	1	m
2	n2	2	f
20	n2	2	f
select * from tt1 where score >=1  and score < 3 order by id;
score	name	id	gender
1	n1	1	m
2	n2	2	f
select * from tt1 where id >=1  and id < 3 order by id;
score	name	id	gender
1	n1	1	m
10	n1	1	m
2	n2	2	f
20	n2	2	f
select score from tt1 where id > 2  and score = 30 order by id;
score
30
select * from tt1 where score >=1  or id < 3 order by id;
score	name	id	gender
1	n1	1	m
10	n1	1	m
2	n2	2	f
20	n2	2	f
3	n3	3	m
30	n3	3	m
