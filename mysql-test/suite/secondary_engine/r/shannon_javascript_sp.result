# 9. JS PROCEDURE with IN/OUT parameters (compute value in JS)
CREATE PROCEDURE js_proc_inout (IN x INTEGER, OUT out_result TEXT)
LANGUAGE JAVASCRIPT
AS $$
var val = x * 2;
out_result = String(val);
sys.exec_sql("SET @_js_out = '" + val + "'");
$$|
SET @_js_out = '';
SET @out_result = '';
CALL js_proc_inout(21, @out_result);
SELECT @out_result, @_js_out;
@out_result	@_js_out
NULL	42
DROP PROCEDURE js_proc_inout;
#
# 10. sys.send_result_set — send structured result sets from JS procedures
#
# 10a. Basic send_result_set with JS object (single row, multiple columns)
CREATE PROCEDURE js_proc_send_result_basic()
LANGUAGE JAVASCRIPT
AS $$
sys.send_result_set({
columns: ["response", "confidence"],
rows: [
["Hello from JS send_result_set", 0.95]
]
});
$$|
CALL js_proc_send_result_basic();
response	confidence
Hello from JS send_result_set	0.95
DROP PROCEDURE js_proc_send_result_basic;
# 10b. send_result_set with multiple rows
CREATE PROCEDURE js_proc_send_result_multi()
LANGUAGE JAVASCRIPT
AS $$
sys.send_result_set({
columns: ["table_name", "row_count", "engine"],
rows: [
["users", 10000, "InnoDB"],
["orders", 50000, "InnoDB"],
["logs", 120000, "Rapid"]
]
});
$$|
CALL js_proc_send_result_multi();
table_name	row_count	engine
users	10000	InnoDB
orders	50000	InnoDB
logs	120000	Rapid
DROP PROCEDURE js_proc_send_result_multi;
