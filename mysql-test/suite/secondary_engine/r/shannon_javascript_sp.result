#
# JavaScript PROCEDURE tests
#
# 1. Basic JS PROCEDURE (no parameters, DML via INSERT)
CREATE PROCEDURE js_proc_no_param ()
LANGUAGE JAVASCRIPT
AS $$
sys.exec_sql("INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata) VALUES('JS Proc Basic', 'Hello from JS PROCEDURE', 'js_proc_basic', 1, JSON_OBJECT('src', 'js_proc'))");
$$|
CALL js_proc_no_param();
SELECT id, segment, document_name FROM js_sp_test WHERE document_name = 'js_proc_basic' ORDER BY id;
id	segment	document_name
7	JS Proc Basic	js_proc_basic
# Verify metadata
SHOW CREATE PROCEDURE js_proc_no_param;
Procedure	sql_mode	Create Procedure	character_set_client	collation_connection	Database Collation
js_proc_no_param	ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION	CREATE DEFINER=`root`@`localhost` PROCEDURE `js_proc_no_param`()
    NO SQL
    LANGUAGE JAVASCRIPT
AS $$
sys.exec_sql("INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata) VALUES('JS Proc Basic', 'Hello from JS PROCEDURE', 'js_proc_basic', 1, JSON_OBJECT('src', 'js_proc'))");
$$	utf8mb4	utf8mb4_0900_ai_ci	utf8mb4_0900_ai_ci
SHOW PROCEDURE STATUS WHERE Name = 'js_proc_no_param';
Db	Name	Type	Language	Definer	Modified	Created	Security_type	Comment	character_set_client	collation_connection	Database Collation
sh_javascript_sp	js_proc_no_param	PROCEDURE	JAVASCRIPT	root@localhost	<modified>	<created>	DEFINER		utf8mb4	utf8mb4_0900_ai_ci	utf8mb4_0900_ai_ci
SELECT routine_name, routine_type, routine_body,
