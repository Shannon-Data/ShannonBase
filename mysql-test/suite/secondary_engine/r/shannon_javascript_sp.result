create database sh_javascript_sp;
use sh_javascript_sp;
CREATE TABLE js_sp_test (
id INT AUTO_INCREMENT PRIMARY KEY,
segment VARCHAR(255) NOT NULL,
text VARCHAR(255) NOT NULL,
document_name VARCHAR(100) DEFAULT NULL,
segment_number INT DEFAULT 1,
metadata JSON DEFAULT (JSON_OBJECT())
) ENGINE=InnoDB;
INSERT INTO js_sp_test (segment, text, document_name, segment_number, metadata)
VALUES 
('What is AutoML?', ('AutoML explanation example text'), 'doc1', 1, JSON_OBJECT('category', 'AI')),
('AutoML automates model building', ('AutoML automates model building'), 'doc1', 2, JSON_OBJECT('category', 'AI')),
('Machine learning basics', ('Basics of machine learning'), 'doc2', 1, JSON_OBJECT('category', 'ML')),
('ShannonBase is an AI-native SQL engine', ('ShannonBase overview'), 'doc3', 1, JSON_OBJECT('category', 'DB'));
CREATE FUNCTION SELECT_DATA () RETURNS TEXT
LANGUAGE JAVASCRIPT AS $$
function select_data() {
return sys.exec_sql("SELECT id + 0 AS id, segment, text, document_name, segment_number, metadata FROM js_sp_test");
}
return select_data();
$$|
SELECT SELECT_DATA();
SELECT_DATA()
[{"id":1,"segment":"What is AutoML?","text":"AutoML explanation example text","document_name":828600164,"segment_number":1,"metadata":"{\"category\": \"AI\"}"},{"id":2,"segment":"AutoML automates model building","text":"AutoML automates model building","document_name":828600164,"segment_number":2,"metadata":"{\"category\": \"AI\"}"},{"id":3,"segment":"Machine learning basics","text":"Basics of machine learning","document_name":845377380,"segment_number":1,"metadata":"{\"category\": \"ML\"}"},{"id":4,"segment":"ShannonBase is an AI-native SQL engine","text":"ShannonBase overview","document_name":862154596,"segment_number":1,"metadata":"{\"category\": \"DB\"}"}]
DROP DATABASE sh_javascript_sp;
