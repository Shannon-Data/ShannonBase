# 7. Error: using LANGUAGE JAVASCRIPT as procedure name
CREATE PROCEDURE JAVASCRIPT (a INTEGER)
LANGUAGE JAVASCRIPT
AS $$ let b = a; $$|
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your MySQL server version for the right syntax to use near 'JAVASCRIPT (a INTEGER)
LANGUAGE JAVASCRIPT
AS $$ let b = a; $$' at line 1
# 8. Lower-case and mixed-case LANGUAGE (minimal body)
CREATE PROCEDURE js_proc_lower (IN x INTEGER)
LANGUAGE javascript
AS $$
var dummy = x;
$$|
CALL js_proc_lower(5);
DROP PROCEDURE js_proc_lower;
CREATE PROCEDURE js_proc_mixed (IN x INTEGER)
LANGUAGE jAvaScRIpt
AS $$
var dummy = x;
$$|
CALL js_proc_mixed(5);
DROP PROCEDURE js_proc_mixed;
# 9. JS PROCEDURE with IN/OUT parameters (SELECT result via user variable)
CREATE PROCEDURE js_proc_inout (IN x INTEGER, OUT out_result TEXT)
LANGUAGE JAVASCRIPT
AS $$
var json = sys.exec_sql("SELECT " + x + " * 2 AS doubled");
var rows = JSON.parse(json);
var val = rows[0].doubled;
out_result = String(val);
sys.exec_sql("SET @_js_out = '" + val + "'");
$$|
SET @_js_out = '';
SET @out_result = '';
CALL js_proc_inout(21, @out_result);
SELECT @out_result, @_js_out;
@out_result	@_js_out
NULL	42
DROP PROCEDURE js_proc_inout;
DROP DATABASE sh_javascript_sp;
